{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start -- --port 3199",
      "startServerReadyPattern": "Ready",
      "url": [
        "http://localhost:3199/",
        "http://localhost:3199/builds",
        "http://localhost:3199/cv"
      ],
      "numberOfRuns": 3,
      "settings": {
        "throttlingMethod": "devtools"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.95 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }]
      }
    },
    "upload": {
      "target": "filesystem",
      "outputDir": ".lighthouseci-reports"
    }
  }
}
